root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.sh]
space_redirects = true

[Makefile]
indent_style = tab

[*.go]
indent_style = tab
indent_size = 4

[*.{py,lua}]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2

[*.{gitconfig,git.aliases}]
indent_style = tab
