{{- $name := "" -}}
{{- $email := "" -}}
{{- $gpg_key_id := "" -}}
{{- $github := "" -}}
{{- $tz := "" -}}

{{- with (index . "user") -}}
{{-   with (index . "name") -}}{{- $name = . -}}{{- end -}}
{{-   with (index . "email") -}}{{- $email = . -}}{{- end -}}
{{-   with (index . "gpg_key_id") -}}{{- $gpg_key_id = . -}}{{- end -}}
{{-   with (index . "github") -}}{{- $github = . -}}{{- end -}}
{{-   with (index . "tz") -}}{{- $tz = . -}}{{- end -}}
{{- end -}}


{{- $noagent := true -}}
{{- $authorized_keys := "" -}}
{{- $config := "" -}}

{{- with (index . "ssh") -}}
{{-   if hasKey . "no_agent" -}}{{- $noagent = (index . "no_agent") -}}{{- end -}}
{{-   with (index . "authorized_keys") -}}{{- $authorized_keys = . -}}{{- end -}}
{{-   with (index . "config") -}}{{- $config = . -}}{{- end -}}
{{- end -}}

{{- if (eq $name "") -}}
{{-   $name = promptString "Display Name" "John Weldon" -}}
{{- end -}}

{{- if (eq $email "") -}}
{{-   $email = promptString "Email Address" "johnweldon4@gmail.com" -}}
{{- end -}}

{{- if (eq $github "") -}}
{{-   $github = promptString "GitHub ID (for importing authorized ssh keys)" "johnweldon" -}}
{{- end -}}

{{- if (eq $tz "") -}}
{{-   $tz = promptString "Timezone (e.g., America/Phoenix, America/New_York)" "America/Phoenix" -}}
{{- end -}}

{{- $profile := env "DOTFILES_PROFILE" -}}
{{- if eq $profile "" -}}{{- $profile = promptStringOnce . "profile" "Install profile (full/minimal)" "full" -}}{{- end -}}

[data]

  profile = {{ $profile | quote }}

  [data.user]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    gpg_key_id = {{ $gpg_key_id | quote }}
    github = {{ $github | quote }}
    tz = {{ $tz | quote }}

  [data.ssh]
    no_agent = {{ $noagent }}
    authorized_keys = [{{ with $authorized_keys}}{{ range . }}
      {{ . | quote }},{{ end }}
    {{ end }}]

    config = '''
{{ $config }}'''
