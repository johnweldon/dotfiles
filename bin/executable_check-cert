#!/usr/bin/env bash
set -euo pipefail

opt=""
case "$(openssl version)" in
Libre*)
	opt=""
	;;
OpenSSL*)
	opt="-ext subjectAltName"
	;;
*)
	opt="-purpose"
	;;
esac

for p in "$@"; do
	IFS=: read -r host port <<<"$p"
	port="${port:-443}"

	# shellcheck disable=SC2086 # opt is a trusted constant set above
	echo |
		openssl s_client -servername "${host}" -connect "${host}:${port}" 2>/dev/null |
		openssl x509 -noout -issuer -subject -fingerprint -dates -email ${opt}
done
